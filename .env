THEME=https://raw.githubusercontent.com/austinsuun/obsidian-AAAA/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgShowBacklinks=true
dgShowLocalGraph=false
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=true
SITE_NAME_HEADER=Genshin Lore Notes
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=genshinlorenotes.vercel.app
SHOW_CREATED_TIMESTAMP=true
TIMESTAMP_FORMAT=MMM dd, yyyy h:mm a
SHOW_UPDATED_TIMESTAMP=true
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=theme-dark mod-windows is-frameless obsidian-app styled-scrollbars show-inline-title is-floating-nav auto-full-screen show-ribbon show-view-header css-settings-manager is-maximized minimal-theme minimal-readable-off minimal-light minimal-default-light minimal-dark minimal-catppuccin-dark links-int-on links-ext-on full-width-media minimal-status-off full-file-names minimal-folding chart-default-width table-default-width img-default-width iframe-default-width map-default-width callouts-default trim-cols checkbox-circle pdf-seamless-on pdf-invert-dark pdf-blend-light sidebar-tabs-default tab-names-off vault-profile-default ribbon-hidden maximize-tables-off tabs-default tab-stack-top minimal-tab-title-hover default is-focused
USE_FULL_RESOLUTION_IMAGES=false
dgPassFrontmatter=false