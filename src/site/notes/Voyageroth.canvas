---
{"dg-publish":true,"permalink":"/voyageroth.canvas/","contentClasses":"canvas-page","dg-note-properties":{}}
---

<div id="Voyagerothcanvas" class="canvas-wrapper hide">
	<svg class="canvas-background">
		<defs>
			<pattern id="canvas-grid-Voyagerothcanvas" width="25" height="25" patternUnits="userSpaceOnUse">
				<circle r="1.5" cx="12.5" cy="12.5"></circle>
			</pattern>
		</defs>
		<rect width="100%" height="100%" fill="url(#canvas-grid-Voyagerothcanvas)"></rect>
	</svg>
	<div class="canvas">
		<svg class="canvas-edges-container" style="position:absolute;width:1px;height:1px;overflow:visible;">
			<defs><filter x="-0.1" y="-0.1" width="1.2" height="1.3" id="edge-label-bg">
			<feFlood flood-color="var(--background-primary)" flood-opacity="1" result="bg"/>
			<feMerge>
				<feMergeNode in="bg"/>
				<feMergeNode in="SourceGraphic"/>
			</feMerge>
		</filter></defs>
		</svg>
		<div class="canvas-node canvas-node-group has-color" data-node-id="cbceb0baa2948330" style="transform: translate(10720px, -9220px); width: 3980px; height: 4240px; --canvas-color: #a882ff; ">
	<div class="canvas-node-label">--- 6.7 LEAKS ---</div>
</div>
<div class="canvas-node canvas-node-group " data-node-id="679cf4b028de1b3d" style="transform: translate(-3480px, -7440px); width: 4460px; height: 1480px;  ">
	<div class="canvas-node-label">Untitled group</div>
</div>
<div class="canvas-node canvas-node-group has-color" data-node-id="bd1abeb120c6650e" style="transform: translate(4600px, -3640px); width: 5240px; height: 1080px; --canvas-color: #e9973f; ">
	<div class="canvas-node-label">Nighttime Whispers in the Echoing Woods</div>
</div>
